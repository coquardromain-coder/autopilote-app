# Variables d'environnement pour le déploiement Dolibarr (Coolify / docker-compose)
# Copiez en .env à côté de docker-compose.dolibarr.yml

# Mot de passe de la base Dolibarr
DOLIBARR_DB_PASSWORD=autopilote_doli_2026

# Mot de passe root MySQL
DOLIBARR_DB_ROOT_PASSWORD=root_doli_2026

# Mot de passe de l'administrateur Dolibarr (login: admin)
DOLIBARR_ADMIN_PASSWORD=Admin@AutoPilote2026

# Nom de la société par défaut dans Dolibarr
DOLIBARR_COMPANY_NAME=AutoPilote Client

# ── Déploiement ──
# 1. Sur Coolify, créez une ressource "Docker Compose" pointant sur
#    docker-compose.dolibarr.yml et renseignez ces variables.
# 2. Mappez le domaine https://dolibarr.famcofinances.com vers le service "dolibarr"
#    (port 80) avec SSL Let's Encrypt activé.
# 3. À la première connexion (admin / DOLIBARR_ADMIN_PASSWORD), activez le module
#    "API REST" : Configuration → Modules → API/Web services.
# 4. Générez une clé API : Utilisateur admin → onglet "Clé API".
# 5. Renseignez l'URL, le login et la clé API dans AutoPilote :
#    Paramètres → Intégrations → Dolibarr (test de connexion automatique).
