# Configuration AutoPilote Backend
# Copiez ce fichier en .env et renseignez vos valeurs

# Port du serveur Express
PORT=4000

# Emplacement de la base SQLite.
# PRODUCTION (Coolify) : pointez vers un VOLUME PERSISTANT pour ne pas perdre
# les données à chaque redéploiement, ex : /app/data/autopilote.db
# (et ajoutez un Persistent Storage Coolify monté sur /app/data).
# Laissez vide en développement (fichier local backend/autopilote.db).
DATABASE_PATH=

# Secret pour signer les jetons JWT (changez-le en production !)
JWT_SECRET=changez-moi-en-une-chaine-aleatoire-longue-et-secrete

# Clé API Anthropic (https://console.anthropic.com)
# Sans cette clé, les agents fonctionnent en mode "démonstration" (réponses simulées)
ANTHROPIC_API_KEY=

# Modèle utilisé par les agents IA
ANTHROPIC_MODEL=claude-sonnet-4-6

# Origine(s) autorisée(s) pour le frontend (CORS).
# Plusieurs origines possibles, séparées par des virgules.
# Ex : https://mon-app.fr,http://localhost:3000
FRONTEND_ORIGIN=http://ruo4s93g0vwuv3ogm0ayatpl.157.180.72.230.sslip.io

# Intégration Google OAuth (Gmail, Calendar, Drive)
# PRODUCTION (recommandé) : renseignez ces 3 variables. Elles ont priorité
# sur le fichier client_secret*.json.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# ⚠️ Doit correspondre EXACTEMENT à un URI autorisé dans la Google Cloud Console.
# Utilisez le chemin /api/auth/... (couvre les proxies qui ne routent que /api/*).
GOOGLE_REDIRECT_URI=https://api.famcofinances.com/api/auth/google/callback
# DÉVELOPPEMENT (alternative) : fichier d'identifiants détecté automatiquement
# (client_secret*.json dans backend/), ou chemin explicite ci-dessous.
# GOOGLE_CREDENTIALS_PATH=client_secret_xxx.apps.googleusercontent.com.json

# URL publique du backend (pour les redirections OAuth réseaux sociaux)
BACKEND_URL=http://localhost:4000

# WhatsApp via Twilio (laisser vide = mode simulation)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Réseaux sociaux (laisser vide = mode simulation)
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Publication WordPress (laisser vide = mode simulation ; configurable aussi par client dans l'UI)
WORDPRESS_URL=
WORDPRESS_USER=
WORDPRESS_PASSWORD=

# Clé de chiffrement AES-256 des identifiants de connecteurs (32+ caractères).
# IMPORTANT en production : définissez une valeur stable et secrète.
ENCRYPTION_KEY=

# Verify token global du webhook WhatsApp Cloud (optionnel : sinon par client)
WHATSAPP_VERIFY_TOKEN=

# ── Interface ADMIN (conseiller AutoPilote) ──
ADMIN_EMAIL=admin@autopilote.fr
ADMIN_PASSWORD=                         # À DÉFINIR (sinon /admin désactivé)

# ── Emails système (SMTP) — sinon mode simulation (journalisé) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=AutoPilote <no-reply@famcofinances.com>
ADMIN_NOTIFY_EMAIL=contact@famcofinances.com  # destinataire des notifs nouveaux clients

# Dolibarr mutualisé pour le provisioning onboarding Option A (optionnel)
SHARED_DOLIBARR_URL=
SHARED_DOLIBARR_APIKEY=

# ── Connecteurs configurés PAR CLIENT dans l'UI (Paramètres → Intégrations) ──
# Aucune variable d'env requise pour : Dolibarr, OpenSign, DocuSeal, Fonoster,
# Hunter.io, Stripe, Search Console, Analytics, Google Business, WhatsApp Cloud.
# Leurs identifiants sont saisis par le client et stockés chiffrés (AES-256).
